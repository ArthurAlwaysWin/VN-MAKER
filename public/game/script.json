{
  "projectId": "galgame-maker-sample",
  "meta": {
    "title": "樱花之约",
    "version": "1.0.0",
    "author": "Galgame Maker Demo",
    "resolution": { "width": 1280, "height": 720 }
  },
  "characters": {
    "sakura": {
      "name": "樱",
      "color": "#FF9CAE",
      "expressions": {
        "normal": "characters/sakura_normal.svg",
        "smile": "characters/sakura_smile.svg",
        "sad": "characters/sakura_sad.svg",
        "surprised": "characters/sakura_surprised.svg"
      }
    },
    "haruki": {
      "name": "春树",
      "color": "#7EB6FF",
      "expressions": {
        "normal": "characters/haruki_normal.svg",
        "smile": "characters/haruki_smile.svg",
        "serious": "characters/haruki_serious.svg"
      }
    }
  },
  "scenes": {
    "start": {
      "name": "序章 — 春日邂逅",
      "pages": [
        {
          "id": "p1",
          "type": "normal",
          "background": "backgrounds/school_gate.svg",
          "characters": [],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.6 },
          "se": null,
          "dialogues": [
            { "speaker": null, "text": "春风轻轻拂过校园的樱花树，花瓣纷纷扬扬地飘落在小径上。", "expression": null },
            { "speaker": null, "text": "新学期的第一天，空气中弥漫着淡淡的花香……", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        },
        {
          "id": "p2",
          "type": "normal",
          "background": "backgrounds/school_gate.svg",
          "characters": [
            { "id": "sakura", "expression": "normal", "position": "center", "x": null, "y": null, "scale": 1 }
          ],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.6 },
          "se": null,
          "dialogues": [
            { "speaker": "sakura", "text": "啊……又是一年春天呢。", "expression": null },
            { "speaker": "sakura", "text": "不知道今年会发生什么有趣的事情。", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        },
        {
          "id": "p3",
          "type": "normal",
          "background": "backgrounds/school_gate.svg",
          "characters": [
            { "id": "sakura", "expression": "surprised", "position": "center", "x": null, "y": null, "scale": 1 },
            { "id": "haruki", "expression": "normal", "position": "left", "x": null, "y": null, "scale": 1 }
          ],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.6 },
          "se": { "file": "audio/se_footstep.mp3" },
          "dialogues": [
            { "speaker": "haruki", "text": "你好！请问这里是樱花学园吗？", "expression": null },
            { "speaker": "sakura", "text": "啊，是的！你是新来的转学生吗？", "expression": null },
            { "speaker": "haruki", "text": "是的，我叫春树。今天第一天来，有点迷路了……", "expression": "smile" },
            { "speaker": "sakura", "text": "欢迎你！我叫樱。走吧，我带你去教室。", "expression": "smile" }
          ],
          "transition": { "type": "fade", "duration": 800 }
        },
        {
          "id": "p4",
          "type": "choice",
          "background": "backgrounds/school_gate.svg",
          "characters": [
            { "id": "sakura", "expression": "smile", "position": "center", "x": null, "y": null, "scale": 1 },
            { "id": "haruki", "expression": "smile", "position": "left", "x": null, "y": null, "scale": 1 }
          ],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.6 },
          "se": null,
          "prompt": "你要怎么回答？",
          "options": [
            { "text": "太好了，谢谢你！", "target": "path_friendly", "setVariable": { "sakura_affection": 1 } },
            { "text": "不用了，我自己能找到。", "target": "path_cold", "setVariable": { "sakura_affection": -1 } }
          ],
          "dialogues": [],
          "transition": { "type": "fade", "duration": 800 }
        }
      ]
    },
    "path_friendly": {
      "name": "温暖的相遇",
      "next": "ending_check",
      "pages": [
        {
          "id": "p1",
          "type": "normal",
          "background": "backgrounds/school_gate.svg",
          "characters": [
            { "id": "sakura", "expression": "smile", "position": "center", "x": null, "y": null, "scale": 1 },
            { "id": "haruki", "expression": "smile", "position": "left", "x": null, "y": null, "scale": 1 }
          ],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.6 },
          "se": null,
          "dialogues": [
            { "speaker": "haruki", "text": "太好了，谢谢你！能在第一天就遇到这么热心的人，真的很幸运。", "expression": null },
            { "speaker": "sakura", "text": "哈哈，不客气！那我们走吧～", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        },
        {
          "id": "p2",
          "type": "normal",
          "background": "backgrounds/classroom.svg",
          "characters": [
            { "id": "sakura", "expression": "normal", "position": "right", "x": null, "y": null, "scale": 1 }
          ],
          "bgm": { "file": "audio/bgm_peaceful.mp3", "volume": 0.5 },
          "se": null,
          "dialogues": [
            { "speaker": "sakura", "text": "这就是我们的教室了。看，你的座位在那边靠窗的位置。", "expression": null },
            { "speaker": "haruki", "text": "靠窗的位置啊……视野真好。", "expression": null },
            { "speaker": "sakura", "text": "对吧！而且从这里可以看到操场旁边的那棵大樱花树。", "expression": "smile" },
            { "speaker": "sakura", "text": "以后有什么不懂的可以尽管来问我哦。", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        }
      ]
    },
    "path_cold": {
      "name": "冷淡的开始",
      "next": "ending_check",
      "pages": [
        {
          "id": "p1",
          "type": "normal",
          "background": "backgrounds/school_gate.svg",
          "characters": [
            { "id": "sakura", "expression": "sad", "position": "center", "x": null, "y": null, "scale": 1 },
            { "id": "haruki", "expression": "serious", "position": "left", "x": null, "y": null, "scale": 1 }
          ],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.6 },
          "se": null,
          "dialogues": [
            { "speaker": "haruki", "text": "不用了，我自己能找到的。谢谢。", "expression": null },
            { "speaker": "sakura", "text": "啊……好吧，那祝你顺利。教学楼就在前面那栋。", "expression": null },
            { "speaker": null, "text": "樱有些失落地目送春树独自走向教学楼的背影。", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        },
        {
          "id": "p2",
          "type": "normal",
          "background": "backgrounds/school_gate.svg",
          "characters": [
            { "id": "sakura", "expression": "sad", "position": "center", "x": null, "y": null, "scale": 1 }
          ],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.6 },
          "se": null,
          "dialogues": [
            { "speaker": "sakura", "text": "（好冷淡啊……不过也许只是紧张吧。）", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        },
        {
          "id": "p3",
          "type": "normal",
          "background": "backgrounds/classroom.svg",
          "characters": [],
          "bgm": { "file": "audio/bgm_peaceful.mp3", "volume": 0.5 },
          "se": null,
          "dialogues": [
            { "speaker": null, "text": "春树独自一人走进了教室，找到了自己的座位坐下。", "expression": null },
            { "speaker": null, "text": "窗外的樱花依然在飘落，只是此刻显得有些寂寞。", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        }
      ]
    },
    "ending_check": {
      "name": "结局判定",
      "pages": [
        {
          "id": "p1",
          "type": "condition",
          "variable": "sakura_affection",
          "operator": ">=",
          "value": 1,
          "trueTarget": "good_ending",
          "falseTarget": "normal_ending"
        }
      ]
    },
    "good_ending": {
      "name": "Good End — 春樱之约",
      "pages": [
        {
          "id": "p1",
          "type": "normal",
          "background": "backgrounds/school_gate.svg",
          "characters": [
            { "id": "sakura", "expression": "smile", "position": "center", "x": null, "y": null, "scale": 1 }
          ],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.7 },
          "se": null,
          "dialogues": [
            { "speaker": null, "text": "放学后，樱在校门口等着春树。", "expression": null },
            { "speaker": "sakura", "text": "春树！一起回家吧？", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        },
        {
          "id": "p2",
          "type": "normal",
          "background": "backgrounds/school_gate.svg",
          "characters": [
            { "id": "sakura", "expression": "smile", "position": "center", "x": null, "y": null, "scale": 1 },
            { "id": "haruki", "expression": "smile", "position": "left", "x": null, "y": null, "scale": 1 }
          ],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.7 },
          "se": null,
          "dialogues": [
            { "speaker": "haruki", "text": "好啊！", "expression": null },
            { "speaker": null, "text": "两人并肩走在铺满樱花花瓣的小路上。", "expression": null },
            { "speaker": null, "text": "这是一个温暖而美好的春日——也许，这就是故事的开始。", "expression": null },
            { "speaker": null, "text": "【GOOD END —— 春樱之约】", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        }
      ]
    },
    "normal_ending": {
      "name": "Normal End — 各自的春天",
      "pages": [
        {
          "id": "p1",
          "type": "normal",
          "background": "backgrounds/school_gate.svg",
          "characters": [],
          "bgm": { "file": "audio/bgm_spring.mp3", "volume": 0.5 },
          "se": null,
          "dialogues": [
            { "speaker": null, "text": "放学的钟声响起。", "expression": null },
            { "speaker": null, "text": "春树独自一人走出校门，回头望了望那棵樱花树。", "expression": null },
            { "speaker": null, "text": "也许明天，会有不同的邂逅也说不定。", "expression": null },
            { "speaker": null, "text": "【NORMAL END —— 各自的春天】", "expression": null }
          ],
          "transition": { "type": "fade", "duration": 800 }
        }
      ]
    }
  }
}
